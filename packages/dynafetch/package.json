{
  "name": "@grabbit-labs/dynafetch",
  "version": "0.2.4",
  "description": "Fetch any website like a real browser. Chrome TLS fingerprinting, JS execution, and request interception in one function call.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "fetch",
    "scraper",
    "browser",
    "tls",
    "fingerprint",
    "chrome",
    "proxy",
    "ssr",
    "spa",
    "headless"
  ],
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "node build.mjs"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "jsdom": "27.0.0",
    "esbuild": "^0.25.0",
    "ws": "^8.19.0",
    "@babel/core": "^7.29.0",
    "@babel/parser": "^7.29.0",
    "@babel/traverse": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/types": "^7.29.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/colebanman/dynafetch"
  }
}
